# Required for Payload (set in Vercel: Project → Settings → Environment Variables)
PAYLOAD_SECRET=your-secret-at-least-32-chars-long

# Postgres connection (this project uses Postgres, not MongoDB)
# Current secure behavior (recommended): sslmode=verify-full
# Libpq compatibility: ...?uselibpqcompat=true&sslmode=require
POSTGRES_URL=postgresql://user:password@host:5432/database?sslmode=verify-full

# Vercel Blob: required for Media uploads in Payload (and /api/upload). Set automatically when you add Blob storage in Vercel.
# BLOB_READ_WRITE_TOKEN=
